{
  "name": "flow-language",
  "displayName": "Flow Language",
  "description": "Official language support for Flow — LSP, autocomplete, type-safe, diagnostics.",
  "version": "0.3.0",
  "publisher": "flow-lang",
  "icon": "icons/flow-file.png",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:flow"],
  "main": "./client/out/extension.js",
  "contributes": {
    "languages": [{
      "id": "flow",
      "aliases": ["Flow", "flow"],
      "extensions": [".flow"],
      "configuration": "./language-configuration.json",
      "icon": { "light": "./icons/flow-file.png", "dark": "./icons/flow-file.png" }
    }],
    "grammars": [{
      "language": "flow",
      "scopeName": "source.flow",
      "path": "./syntaxes/flow.tmLanguage.json"
    }],
    "snippets": [{ "language": "flow", "path": "./snippets/flow.json" }],
    "configuration": {
      "type": "object",
      "title": "Flow",
      "properties": {
        "flow.lsp.trace": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Traces LSP communication"
        },
        "flow.path": {
          "type": "string",
          "default": "",
          "description": "Path to flowc executable (auto-detected if empty)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "postinstall": "cd client && npm install && cd ../server && npm install"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.6.0"
  }
}
